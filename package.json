{
  "name": "arduino-monitor-ambient-light",
  "productName": "Monitor Ambient Light",
  "version": "1.0.0",
  "description": "Monitor Ambient Light — Arduino RGB LED control over serial (COM) on Windows",
  "author": "Aytac Malkoc",
  "homepage": "https://github.com/aytacmalkoc/arduino-monitor-ambient-light",
  "license": "MIT",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i ./input.css -o ./styles.css --minify",
    "watch:css": "tailwindcss -i ./input.css -o ./styles.css --watch",
    "rebuild": "electron-rebuild -f --only serialport",
    "postinstall": "patch-package && electron-rebuild -f --only serialport",
    "export": "npm run build:css && node scripts/export-all.js",
    "dist:win": "npm run build:css && electron-builder --win",
    "dist:mac": "npm run build:css && electron-builder --mac",
    "dist:linux": "npm run build:css && electron-builder --linux"
  },
  "keywords": [
    "electron",
    "arduino",
    "serial"
  ],
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/manrope": "^5.2.5",
    "@tailwindcss/forms": "^0.5.9",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "patch-package": "^8.0.1",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "express": "^4.22.1",
    "serialport": "^12.0.0",
    "winreg": "^1.2.5"
  },
  "build": {
    "appId": "com.aytacmalkoc.monitor-ambient-light",
    "productName": "Monitor Ambient Light",
    "directories": {
      "output": "dist"
    },
    "icon": "icons/icon.png",
    "files": [
      "package.json",
      "main/**/*",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer/**/*",
      "fonts/**/*",
      "!design/**",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/serialport/**/*",
      "**/node_modules/@serialport/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage"
      ]
    },
    "publish": null
  }
}
